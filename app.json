{
  "expo": {
    "name": "Limkokwing",
    "slug": "Limkokwings",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/limko.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/limko.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.nteboheleng.Limkokwings"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "0a5dc789-ea03-4f6c-9f76-8ab026cca338"
      }
    },
    "plugins": [
      "expo-font",
      "expo-video"
    ]
  }
}
